#: /usr/lib64/python3.6/argparse.py:295
msgid "usage: "
msgstr "uso: "

#: /usr/lib64/python3.6/argparse.py:830
msgid ".__call__() not defined"
msgstr ".__call__() não definido"

#: /usr/lib64/python3.6/argparse.py:1127
#, python-format
msgid "unknown parser %(parser_name)r (choices: %(choices)s)"
msgstr "analisador desconhecido %(parser_name)r (escolhas: %(choices)s)"

#: /usr/lib64/python3.6/argparse.py:1181
#, python-format
msgid "argument \"-\" with mode %r"
msgstr "argumento \"-\" com modo %r"

#: /usr/lib64/python3.6/argparse.py:1189
#, python-format
msgid "can't open '%s': %s"
msgstr "não é possível abrir '%s': %s"

#: /usr/lib64/python3.6/argparse.py:1393
#, python-format
msgid "cannot merge actions - two groups are named %r"
msgstr "não foi possível mesclar ações - dois grupos são chamados %r"

#: /usr/lib64/python3.6/argparse.py:1431
msgid "'required' is an invalid argument for positionals"
msgstr "'required' é um argumento inválido para posicionais"

#: /usr/lib64/python3.6/argparse.py:1453
#, python-format
msgid ""
"invalid option string %(option)r: must start with a character "
"%(prefix_chars)r"
msgstr ""
"string de opção inválida %(option)r: deve iniciar com um caractere %"
"(prefix_chars)r"

#: /usr/lib64/python3.6/argparse.py:1473
#, python-format
msgid "dest= is required for options like %r"
msgstr "dest= é necessário para opções como %r"

#: /usr/lib64/python3.6/argparse.py:1490
#, python-format
msgid "invalid conflict_resolution value: %r"
msgstr "valor conflict_resolution inválido: %r"

#: /usr/lib64/python3.6/argparse.py:1508
#, python-format
msgid "conflicting option string: %s"
msgid_plural "conflicting option strings: %s"
msgstr[0] "string com opção conflitante: %s"
msgstr[1] "strings com opção conflitante: %s"

#: /usr/lib64/python3.6/argparse.py:1574
msgid "mutually exclusive arguments must be optional"
msgstr "argumento mutuamente exclusivo deve ser opcional"

#: /usr/lib64/python3.6/argparse.py:1637
msgid "positional arguments"
msgstr "argumentos posicionais"

#: /usr/lib64/python3.6/argparse.py:1638
msgid "optional arguments"
msgstr "argumentos opcionais"

#: /usr/lib64/python3.6/argparse.py:1653
msgid "show this help message and exit"
msgstr "mostra esta mensagem de ajuda e sai"

#: /usr/lib64/python3.6/argparse.py:1684
msgid "cannot have multiple subparser arguments"
msgstr "não pode ter múltiplos argumentos de sub-analisador"

#: /usr/lib64/python3.6/argparse.py:1736
#, python-format
msgid "unrecognized arguments: %s"
msgstr "argumentos não reconhecidos: %s"

#: /usr/lib64/python3.6/argparse.py:1833
#, python-format
msgid "not allowed with argument %s"
msgstr "não permitido com argumento %s"

#: /usr/lib64/python3.6/argparse.py:1879 /usr/lib64/python3.6/argparse.py:1893
#, python-format
msgid "ignored explicit argument %r"
msgstr "argumento explicitamente ignorado %r"

#: /usr/lib64/python3.6/argparse.py:2000
#, python-format
msgid "the following arguments are required: %s"
msgstr "os argumentos seguintes são ignorados: %s"

#: /usr/lib64/python3.6/argparse.py:2015
#, python-format
msgid "one of the arguments %s is required"
msgstr "um dos argumentos %s são necessários"

#: /usr/lib64/python3.6/argparse.py:2058
msgid "expected one argument"
msgstr "espera-se um argumento"

#: /usr/lib64/python3.6/argparse.py:2059
msgid "expected at most one argument"
msgstr "espera-se no máximo um argumento"

#: /usr/lib64/python3.6/argparse.py:2060
msgid "expected at least one argument"
msgstr "espera-se pelo menos um argumento"

#: /usr/lib64/python3.6/argparse.py:2062
#, python-format
msgid "expected %s argument"
msgid_plural "expected %s arguments"
msgstr[0] "espera-se %s argumento"
msgstr[1] "espera-se %s argumentos"

#: /usr/lib64/python3.6/argparse.py:2122
#, python-format
msgid "ambiguous option: %(option)s could match %(matches)s"
msgstr "opção ambígua: %(option)s poderia ser o mesmo que %(matches)s"

#: /usr/lib64/python3.6/argparse.py:2185
#, python-format
msgid "unexpected option string: %s"
msgstr "string de opção inesperada: %s"

#: /usr/lib64/python3.6/argparse.py:2289
#, python-format
msgid "%r is not callable"
msgstr "%r não é um chamável"

#: /usr/lib64/python3.6/argparse.py:2306
#, python-format
msgid "invalid %(type)s value: %(value)r"
msgstr "valor %(type)s inválido: %(value)r"

#: /usr/lib64/python3.6/argparse.py:2317
#, python-format
msgid "invalid choice: %(value)r (choose from %(choices)s)"
msgstr "escolha inválida: %(value)r (escolha entre %(choices)s)"

#: /usr/lib64/python3.6/argparse.py:2393
#, python-format
msgid "%(prog)s: error: %(message)s\n"
msgstr "%(prog)s: erro: %(message)s\n"

#: src/syspurpose/cli.py:29
#, python-brace-format
msgid ""
"Warning: A {attr} of \"{download_value}\" was recently set for this system "
"by the entitlement server administrator.\n"
"{advice}"
msgstr ""
"Aviso: Um {attr} de \"{download_value}\" foi recentemente definido para este "
"sistema pelo administrador do servidor de direitos.\n"
"{advice}"

#: src/syspurpose/cli.py:31
#, python-brace-format
msgid "If you'd like to overwrite the server side change please run: {command}"
msgstr ""
"Se você gostaria de sobrescrever a alteração do lado do servidor, execute: "
"{command}"

#: src/syspurpose/cli.py:47
#, python-brace-format
msgid "Added \"{value}\" to {prop_name}."
msgstr "Adicionado \"{value}\" a {prop_name}."

#: src/syspurpose/cli.py:50
#, python-brace-format
msgid "Not adding value \"{value}\" to {prop_name}; it already exists."
msgstr "Não adicionando o valor \"{value}\" para {prop_name}; ele já existe."

#: src/syspurpose/cli.py:56 src/syspurpose/cli.py:85
#, python-brace-format
msgid "{attr} updated."
msgstr "{attr} atualizado."

#: src/syspurpose/cli.py:79
#, python-brace-format
msgid "Removed \"{val}\" from {name}."
msgstr "Removido \"{val}\" de {name}."

#: src/syspurpose/cli.py:81
#, python-brace-format
msgid "Not removing value \"{val}\" from {name}; it was not there."
msgstr "Não removendo o valor \"{val}\" de {name}; ele não estava lá."

#: src/syspurpose/cli.py:108
#, python-brace-format
msgid "{attr} set to \"{val}\"."
msgstr "{attr} definido para \"{val}\"."

#: src/syspurpose/cli.py:129
#, python-brace-format
msgid "{attr} unset."
msgstr "{attr} apagado."

#: src/syspurpose/cli.py:157
msgid "System Syspurpose Management Tool"
msgstr "Ferramenta de Gerenciamento de Sistema Syspurpose"

#: src/syspurpose/cli.py:158 src/syspurpose/cli.py:353
msgid ""
"The 'syspurpose' command is deprecated and will be removed in a future major "
"release. Please use the 'subscription-manager syspurpose' command going "
"forward."
msgstr ""
"O comando 'syspurpose' está obsoleto e será removido em uma futura versão "
"principal. Por favor, utilize o comando 'subscription-manager syspurpose' "
"daqui para frente."

#: src/syspurpose/cli.py:165 src/syspurpose/cli.py:230
msgid "The value(s) to add"
msgstr "O(s) valor(es) para adicionar"

#: src/syspurpose/cli.py:169 src/syspurpose/cli.py:252
msgid "The value(s) to remove"
msgstr "O(s) valor(es) para remover"

#: src/syspurpose/cli.py:173 src/syspurpose/cli.py:195
msgid "The value to set"
msgstr "O valor a ser definido"

#: src/syspurpose/cli.py:183
msgid "Sets the value for the given property"
msgstr "Define o valor para a propriedade especificada"

#: src/syspurpose/cli.py:189 src/syspurpose/cli.py:211
msgid "The name of the property to set/update"
msgstr "O nome da propriedade para definir / atualizar"

#: src/syspurpose/cli.py:204
msgid "Unsets (clears) the value for the given property"
msgstr "Desativa (limpa) o valor da propriedade especificada"

#: src/syspurpose/cli.py:218
msgid "Adds the value(s) to the given property"
msgstr "Adiciona o(s) valor(es) à propriedade especificada"

#: src/syspurpose/cli.py:224 src/syspurpose/cli.py:246
msgid "The name of the property to update"
msgstr "O nome da propriedade para atualizar"

#: src/syspurpose/cli.py:240
msgid "Removes the value(s) from the given property"
msgstr "Remove o(s) valor(es) da propriedade especificada"

#: src/syspurpose/cli.py:262
msgid "Set the system role to the system syspurpose"
msgstr "Define um papel do sistema para o syspurpose do sistema"

#: src/syspurpose/cli.py:270
msgid "Clear set role"
msgstr "Limpa o papel definido"

#: src/syspurpose/cli.py:278
msgid "Add addons to the system syspurpose"
msgstr "Adiciona complementos ao syspurpose do sistema"

#: src/syspurpose/cli.py:286
msgid "Remove addons from the system syspurpose"
msgstr "Remove complementos do syspurpose do sistema"

#: src/syspurpose/cli.py:293
msgid "Clear set addons"
msgstr "Limpa complementos definidos"

#: src/syspurpose/cli.py:301
msgid "Set the system sla"
msgstr "Define o SLA do sistema"

#: src/syspurpose/cli.py:308
msgid "Clear set sla"
msgstr "Limpa o SLA definido"

#: src/syspurpose/cli.py:316
msgid "Set the system usage"
msgstr "Define o uso do sistema"

#: src/syspurpose/cli.py:324
msgid "Clear set usage"
msgstr "Limpa uso definido"

#: src/syspurpose/cli.py:332
msgid "Show the current system syspurpose"
msgstr "Mostra o sistema atual syspurpose"

#: src/syspurpose/cli.py:350
msgid ""
"WARNING: Setting syspurpose in containers has no effect.\n"
"Please run syspurpose on the host.\n"
msgstr ""
"AVISO: A configuração do syspurpose nos contêineres não tem efeito.\n"
"Execute o syspurpose no host.\n"

#: src/syspurpose/cli.py:364
msgid ""
"Warning: Unable to sync system purpose with subscription management server: "
"subscription_manager module is not available."
msgstr ""
"Aviso: Não foi possível sincronizar a finalidade do sistema com o servidor "
"de gerenciamento de assinaturas: o módulo subscription_manager não está "
"disponível."

#: src/syspurpose/files.py:106
msgid "Error: Malformed data in file {}; please review and correct."
msgstr "Erro: Dados malformados no arquivo {}; revise e corrija."

#: src/syspurpose/files.py:112
msgid ""
"Cannot read syspurpose file {}\n"
"Are you root?"
msgstr ""
"Não é possível ler o arquivo syspurpose {}\n"
"Você está root?"

#: src/syspurpose/files.py:466
#, python-brace-format
msgid ""
"Warning: Provided value \"{val}\" is not included in the list of valid "
"values for attribute {attr}:"
msgstr ""
"Aviso: O valor fornecido \"{val}\" não está incluído na lista de valores "
"válidos para o atributo {attr}:"

#: src/syspurpose/files.py:473
#, python-brace-format
msgid ""
"Warning: Provided key \"{key}\" is not included in the list of valid keys:"
msgstr ""
"Aviso: A chave fornecida \"{key}\" não está incluída na lista de chaves "
"válidas:"

#: src/syspurpose/main.py:32
msgid "User interrupted process"
msgstr "Processo interrompido pelo usuário"

#: src/syspurpose/utils.py:59
msgid ""
"Cannot create directory {}\n"
"Are you root?"
msgstr ""
"Não é possível criar o diretório {}\n"
"Você é root?"

#: src/syspurpose/utils.py:80
msgid ""
"Cannot create file {}\n"
"Are you root?"
msgstr ""
"Não é possível criar o arquivo {}\n"
"Você é root?"

