#: src/plugins/dnf/product_id.py:75
msgid "Installed products updated."
msgstr "Nainstalované produkty zaktualizovány."

#: src/plugins/dnf/subscription_manager.py:46
#, python-format
msgid ""
"\n"
"*** WARNING ***\n"
"The subscription for following product(s) has expired:\n"
"%s\n"
"You no longer have access to the repositories that provide these products.  "
"It is important that you apply an active subscription in order to resume "
"access to security and other critical updates. If you don't have other "
"active subscriptions, you can renew the expired subscription.  "
msgstr ""
"\n"
"*** VAROVÁNÍ ***\n"
"Platnost předplatných pro následující produkty skončila:\n"
"%s\n"
"Nemáte už přístup k repozitářům, které tyto produkty poskytují.  Je důležité "
"použít aktivní předplatné, aby byl obnoven přístup k aktualizacím "
"zabezpečení a ostatním kritickým aktualizacím. Pokud nemáte žádná další "
"aktivní předplatná, je možné ta skončená obnovit.  "

#: src/plugins/dnf/subscription_manager.py:57
msgid ""
"\n"
"This system is not registered with an entitlement server. You can use "
"subscription-manager to register.\n"
msgstr ""
"\n"
"Tento systém není zaregistrován u serveru pro správu nároků. K registraci je "
"možné použít subscription-manager.\n"

#: src/plugins/dnf/subscription_manager.py:63
msgid ""
"\n"
"This system is not registered with an entitlement server. You can use \"rhc"
"\" or \"subscription-manager\" to register.\n"
msgstr ""
"\n"
"Tento systém není zaregistrován u serveru pro správu nároků. K registraci je "
"možné použít „rhc“ nebo „subscription-manager“.\n"

#: src/plugins/dnf/subscription_manager.py:70
msgid ""
"\n"
"This system is registered with an entitlement server, but is not receiving "
"updates. You can use subscription-manager to assign subscriptions.\n"
msgstr ""
"\n"
"Tento systém je zaregistrován u severu pro správu nároků, ale nedostává "
"aktualizace. Předplatné je možné přidělit pomocí subscription-manager.\n"

#: src/plugins/dnf/subscription_manager.py:77
#, python-brace-format
msgid ""
"\n"
"This system has release set to {release_version} and it receives updates "
"only for this release.\n"
msgstr ""
"\n"
"Tento systém má vydání nastaveno na {release_version} a dostává aktualizace "
"pouze pro toto vydání.\n"

